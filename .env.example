# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# On Azure App Service, set these in App Settings (Environment variables), not here.

FLASK_ENV=development
FLASK_SECRET_KEY=replace-with-a-strong-random-64-char-string

# PostgreSQL connection string
# Format: postgresql://user:pass@host:5432/dbname?sslmode=require
# Special chars in password: # → %23, @ → %40, $ → %24, ! → %21
DATABASE_URL=postgresql://user:password@host:5432/asset_mgmt_v2?sslmode=require

# Azure AD (SSO — optional if using local login only)
# AZURE_CLIENT_ID=your-app-registration-client-id
# AZURE_CLIENT_SECRET=your-client-secret
# AZURE_AUTHORITY=https://login.microsoftonline.com/your-tenant-id
# AZURE_SCOPE=https://graph.microsoft.com/.default
# AZURE_REDIRECT_PATH=/auth

# ── Email: Microsoft Graph (recommended) ─────────────────────────────────────
MAIL_PROVIDER=graph
MAIL_TENANT_ID=your-azure-tenant-id
MAIL_CLIENT_ID=your-app-registration-client-id
MAIL_CLIENT_SECRET=your-client-secret-value
MAIL_MAILBOX=helpdesk@yourcompany.com
MAIL_FROM=iMocha Helpdesk <helpdesk@yourcompany.com>
MAIL_AUTO_REPLY=1
MAIL_POLL_INTERVAL=60

# ── AI Assistant ──────────────────────────────────────────────────────────────
# Get Gemini key free at aistudio.google.com (personal Gmail, no billing)
GEMINI_API_KEY=
# Get Groq key free at console.groq.com
GROQ_API_KEY=

# ── Optional ──────────────────────────────────────────────────────────────────
APP_TIMEZONE=Asia/Kolkata
# APP_BASE_URL=https://your-app.azurewebsites.net
# ADMIN_EMAIL=admin@yourcompany.com
# SLA_WARN_MINUTES=60
